#:kivy 2.0.0

<PongBall>:
    size: 35, 35
    canvas:
        Ellipse:
            pos: self.pos
            size: self.size

<PongPaddle>:
    size: 25, 160
    canvas:
        Rectangle:
            pos: self.pos
            size: self.size

<PongGame>:
    ball: pong_ball
    player1: player_left
    player2: player_right

    canvas:
        Rectangle:
            pos: self.center_x - 3, 0
            size: 6, self.height

    Label:
        font_size: 60
        center_x: root.width / 4
        top: root.top - 35
        text: str(root.player1.score)

    Label:
        font_size: 60
        center_x: root.width * 3 / 4
        top: root.top - 35
        text: str(root.player2.score)

    Label:
        font_size: 16
        center_x: root.center_x
        y: 10
        text: 'W/S — левый игрок | ↑/↓ — правый игрок | Space — новая игра'

    PongBall:
        id: pong_ball
        center: root.center

    PongPaddle:
        id: player_left
        x: root.x + 20
        center_y: root.center_y

    PongPaddle:
        id: player_right
        x: root.width - self.width - 20
        center_y: root.center_y
